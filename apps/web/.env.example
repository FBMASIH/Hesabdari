# ── Web Frontend Environment ───────────────────────────────────
#
# API requests go through Next.js rewrite proxy (same-origin).
# The browser NEVER calls the backend directly — all /api/* calls
# are proxied server-side. This means:
#   - No CORS issues (same-origin)
#   - Backend URL is never exposed to the browser
#   - Works from any machine/IP without CORS configuration
#
# Set the backend URL for the server-side proxy:
API_BACKEND_URL=http://localhost:4000

# App display name
NEXT_PUBLIC_APP_NAME=Hesabdari

# DO NOT set NEXT_PUBLIC_API_URL unless you want the browser to
# call the API directly (bypasses the proxy, requires CORS setup).
# NEXT_PUBLIC_API_URL=
