{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pnpm typecheck)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm test)",
      "Bash(pnpm format)",
      "Bash(pnpm format:check)",
      "Bash(pnpm build)",
      "Bash(pnpm db:generate)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- .)",
      "Bash(git clean -f*)",
      "Bash(*JWT_SECRET*)",
      "Bash(*DATABASE_URL*)",
      "Bash(cat .env)",
      "Bash(cat */.env)"
    ]
  }
}
