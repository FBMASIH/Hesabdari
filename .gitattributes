# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Force text for known source types
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sql text eol=lf
*.prisma text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.graphql text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary

# Lock files — generated, treat as binary for merge
pnpm-lock.yaml -diff linguist-generated=true
